{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    "group:monorepos",
    "group:linters",
    "schedule:earlyMondays"
  ],
  "schedule": [
    "before 7am every weekday"
  ],
  "timezone": "Europe/Berlin",
  "labels": [
    "dependencies"
  ],
  "platformAutomerge": true,
  "automergeStrategy": "squash",
  "prConcurrentLimit": 5,
  "packageRules": [
    {
      "matchManagers": [
        "gomod"
      ],
      "groupName": "Go dependencies",
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "matchManagers": [
        "gomod"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": "Go dependencies (major)"
    },
    {
      "matchManagers": [
        "npm"
      ],
      "matchFileNames": [
        "tests/**"
      ],
      "groupName": "Test dependencies",
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "matchManagers": [
        "npm"
      ],
      "matchFileNames": [
        "tests/**"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": "Test dependencies (major)"
    },
    {
      "matchManagers": [
        "dockerfile"
      ],
      "groupName": "Docker base images",
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "GitHub Actions",
      "automerge": true,
      "automergeType": "pr"
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "automergeType": "branch",
    "schedule": [
      "before 4am on sunday"
    ]
  }
}
