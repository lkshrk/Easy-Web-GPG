# Multi-stage Dockerfile for running tests without local dependencies
FROM golang:1.25-alpine AS go-test

# Install build dependencies
RUN apk add --no-cache git make gcc musl-dev

# Set working directory
WORKDIR /app

# Copy go mod files
COPY go.mod go.sum ./
RUN go mod download

# Copy source code
COPY . .

# Run Go tests
CMD ["go", "test", "-race", "-v", "./..."]

# ========================================================================

FROM mcr.microsoft.com/playwright:v1.45.0-jammy AS playwright-test

# Install Node.js dependencies
WORKDIR /app/tests
COPY tests/package*.json ./
RUN npm ci

# Copy test files
COPY tests/ ./

# Install Playwright browsers
RUN npx playwright install --with-deps chromium

# Run Playwright tests
# The app should be running on BASE_URL (default: http://localhost:8080)
CMD ["npx", "playwright", "test", "--reporter=list"]

# ========================================================================

FROM alpine:3.19 AS test-runner

# Install curl for health checks
RUN apk add --no-cache curl bash

# Set working directory
WORKDIR /app

# Copy test scripts
COPY docker/run-tests.sh /usr/local/bin/run-tests.sh
RUN chmod +x /usr/local/bin/run-tests.sh

# Run all tests
CMD ["/usr/local/bin/run-tests.sh"]
